# Copy this file to `.env` in the backend/ directory and edit as needed.
# Every value here has a safe default in app/core/config.py, but you should
# override SECRET_KEY and DEFAULT_ADMIN_PASSWORD before anything but local use.

ENVIRONMENT=development
DEBUG=true

HOST=127.0.0.1
PORT=8000

# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

DATABASE_URL=sqlite+aiosqlite:///./data/bunty.db

SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

ACTIVE_PROVIDER=ollama
